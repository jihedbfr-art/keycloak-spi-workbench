<?xml version="1.0" encoding="UTF-8"?>
<archetype-descriptor xmlns="http://maven.apache.org/plugin-tools/archetype-descriptor/1.0.0"
                       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                       xsi:schemaLocation="http://maven.apache.org/plugin-tools/archetype-descriptor/1.0.0 http://maven.apache.org/xsd/archetype-descriptor-1.0.0.xsd"
                       name="keycloak-spi-authenticator">

    <requiredProperties>
        <requiredProperty key="authenticatorName">
            <defaultValue>Example</defaultValue>
        </requiredProperty>
        <requiredProperty key="providerId">
            <defaultValue>example-authenticator</defaultValue>
        </requiredProperty>
        <requiredProperty key="displayName">
            <defaultValue>Example Authenticator</defaultValue>
        </requiredProperty>
        <requiredProperty key="keycloakVersion">
            <defaultValue>26.6.1</defaultValue>
        </requiredProperty>
    </requiredProperties>

    <fileSets>
        <fileSet filtered="true" packaged="false" encoding="UTF-8">
            <directory></directory>
            <includes>
                <include>pom.xml</include>
                <include>README.md</include>
            </includes>
        </fileSet>
        <fileSet filtered="true" packaged="true" encoding="UTF-8">
            <directory>src/main/java</directory>
            <includes>
                <include>**/*.java</include>
            </includes>
        </fileSet>
        <fileSet filtered="true" packaged="false" encoding="UTF-8">
            <directory>src/main/resources</directory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>
        <fileSet filtered="true" packaged="true" encoding="UTF-8">
            <directory>src/test/java</directory>
            <includes>
                <include>**/*.java</include>
            </includes>
        </fileSet>
    </fileSets>

</archetype-descriptor>
